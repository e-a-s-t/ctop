{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.2/.schema/devbox.schema.json",
  "packages": [
    "rustc@latest",
    "cargo@latest",
    "rustfmt@latest",
    "clippy@latest",
    "pkg-config@latest",
    "openssl@latest",
    "git@latest"
  ],
  "shell": {
    "scripts": {
      "run": "cargo run --manifest-path ctop-rs/Cargo.toml",
      "build": "cargo build --manifest-path ctop-rs/Cargo.toml",
      "test": "cargo test --manifest-path ctop-rs/Cargo.toml",
      "fmt": "cargo fmt --all --manifest-path ctop-rs/Cargo.toml",
      "lint": "cargo clippy --all-targets -- -D warnings --manifest-path ctop-rs/Cargo.toml",
      "check": "cargo check --manifest-path ctop-rs/Cargo.toml"
    }
  }
}
